# Database - local Supabase (port 54332; does not conflict with readytowork-local)
DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:54332/postgres
PAYLOAD_SECRET=YOUR_SECRET_HERE # Generate it!
BLOB_READ_WRITE_TOKEN=YOUR_READ_WRITE_TOKEN_HERE # Vercel Blob Example

RESEND_API_KEY=re_xxxxxxxx # Email Configuration
EMAIL_FROM=noreply@yourdomain.com # Email Configuration

# Supabase (for /api/ping keep-alive cron — use project URL + anon key from Supabase dashboard)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# Create table in Supabase SQL: CREATE TABLE health_check (id serial PRIMARY KEY); INSERT INTO health_check (id) VALUES (1);
